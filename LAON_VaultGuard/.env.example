# ─── 서버 ───
PORT=3101
HOST=0.0.0.0

# ─── LLM API (최소 1개) ───
OPENAI_API_KEY=sk-your-key
DEEPSEEK_API_KEY=sk-your-key
CLAUDE_API_KEY=sk-ant-...
MINIMAX_API_KEY=
MIMO_API_KEY=

# Ollama (로컬/오프라인 모드 — API 키 불필요)
# brew install ollama && ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# LLM 설정 (쉼표 구분, 최소 1개 권장 2개 이상)
LLM_PROVIDERS=deepseek,claude,ollama
LLM_MODE=parallel

# ─── Git ───
GITHUB_TOKEN=
GITLAB_TOKEN=

# GitHub App OAuth (대시보드 GitHub 연동용)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3101/api/oauth/github/callback

# ─── 스캔 최적화 ───
SCAN_CRON=0 */6 * * *
SCAN_TIMEOUT_MS=60000
SCAN_MAX_CANDIDATES=500
SCAN_CACHE_ENABLED=true
SCAN_TIERED_LLM=true
SCAN_LIGHT_PROVIDERS=minimax,ollama
SCAN_HEAVY_PROVIDERS=claude,deepseek
SCAN_BATCH_SIZE=50

# ─── 로그 ───
LOG_RETENTION_DAYS=30

# ─── DB 저장소 경로 ───
DB_PATH=./data

# ─── 디바이스 ───
DEVICE_NAME=Dennis-MacBook

# ─── 리포트 (daily | weekly | off) ───
REPORT_SCHEDULE=daily

# ─── 알람 ───
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TEAMS_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ─── 이메일 ───
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
