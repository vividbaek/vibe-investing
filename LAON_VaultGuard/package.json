{
  "name": "laon-vaultguard",
  "version": "0.5.0",
  "private": true,
  "description": "LLM-based Automated Observer for Non-public Keys",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "laon-vaultguard": "./src/cli.ts"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --external:simple-git",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "scan": "tsx src/cli.ts scan",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.10",
    "openai": "^4.50.0",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/nodemailer": "^8.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
