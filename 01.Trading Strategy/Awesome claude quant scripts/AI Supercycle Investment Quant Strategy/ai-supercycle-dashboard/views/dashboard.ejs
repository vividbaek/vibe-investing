        html += '<table><thead><tr>';
        html += '<th>' + $('tTableTicker') + '</th><th>' + $('tTableName') + '</th><th>' + $('tTableLayer') + '</th><th>' + $('tTableScore') + '</th><th>' + $('tTableAction') + '</th>';
        html += '<th>' + $('tTablePosition') + '</th><th>' + $('tTablePrice') + '</th><th>' + $('tTableStopLoss') + '</th><th>' + $('tTableAvgDown') + '</th><th>' + $('tTableThesis') + '</th>';
        html += '</tr></thead><tbody>';
        const actionColors = { STRONG_BUY: '#6ee7b7', BUY: '#34d399', HOLD: '#fbbf24', AVG_DOWN: '#fb923c', SELL: '#f87171', STRONG_SELL: '#ef4444' };
        data.signals.forEach(s => {
          html += '<tr>';
          html += '<td><strong>' + s.ticker + '</strong></td>';
          html += '<td>' + s.name + (LANG === 'ko' && s.nameKr && s.nameKr !== s.name ? ' / ' + s.nameKr : '') + '</td>';
          html += '<td>Layer ' + s.layer + '</td>';
          html += '<td>' + s.score + '</td>';
          html += '<td><span style="color:' + (actionColors[s.action] || '#94a3b8') + ';font-weight:700;">' + actLabel(s.action) + '</span></td>';
          html += '<td>' + s.positionSizePct + '%</td>';
          html += '<td>$' + (s.currentPrice || 0).toFixed(2) + '</td>';
          html += '<td style="color:#f87171;">$' + (s.stopLoss || 0).toFixed(2) + '</td>';
          html += '<td style="color:#fb923c;">$' + (s.avgDownPrice || 0).toFixed(2) + '</td>';
          html += '<td style="font-size:0.7rem;">' + (s.thesis || '') + '</td>';
          html += '</tr>';
        });
        html += '</tbody></table>';

        if (data.signals.length === 0) {
          html += '<div class="alert alert-info">' + $('tNoStocks') + '</div>';
        }

        html += '<div class="alert alert-info" style="margin-top:10px;">' + $('tDisclaimer') + '</div>';
        html += '</div>';

        container.innerHTML = html;
      } catch(e) {
        container.innerHTML = '<div class="alert alert-error">' + $('statusError') + e.message + '</div>';
      }
    }

    function switchScenario(profile) {
      currentScenario = profile;
      document.querySelectorAll('.scenario-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.scenario-content').forEach(c => c.classList.remove('active'));
      document.querySelector('[onclick="switchScenario(\'' + profile + '\')"]')?.classList.add('active');
      document.getElementById('scenario-' + profile)?.classList.add('active');
      loadStrategy(profile);
    }

    async function runLLMAnalysis() {
      const output = document.getElementById('llmOutput');
      const content = document.getElementById('llmContent');
      output.style.display = 'block';
      content.innerHTML = '<div class="loading"><div class="spinner"></div>' + $('tRunningLLM') + '</div>';

      const provider = document.getElementById('llmProvider').value;
      const apiKey = document.getElementById('apiKey').value;

      try {
        const data = await fetchAPI('/llm/analyze', 'POST', { provider, apiKey: apiKey || undefined, language: LANG });
        const analysis = data.analysis;

        let html = '<div class="alert alert-info">' + $('tLLMProvider') + ' <strong>' + data.provider + '</strong></div>';
        html += '<h3>' + $('tMarketSummary') + '</h3><p>' + (analysis.marketSummary || 'N/A') + '</p>';

        if (analysis.topPicks?.length > 0) {
          html += '<h3>' + $('tTopPicks') + '</h3><table><thead><tr><th>' + $('tTableTicker') + '</th><th>' + $('tTableAction') + '</th><th>Confidence</th><th>Rationale</th></tr></thead><tbody>';
          analysis.topPicks.forEach(p => {
            html += '<tr><td><strong>' + p.ticker + '</strong></td><td style="color:#34d399;">' + p.action + '</td><td>' + p.confidence + '%</td><td>' + p.rationale + '</td></tr>';
          });
          html += '</tbody></table>';
        }

        if (analysis.layerAnalysis) {
          html += '<h3>' + $('tLayerAnalysis') + '</h3>';
          for (const [layer, info] of Object.entries(analysis.layerAnalysis)) {
            const l = layer.replace('layer', '');
            html += '<div style="margin:6px 0;"><span class="badge ' + ({1:'badge-layer1',2:'badge-layer2',3:'badge-layer3',4:'badge-layer4'})[l] + '">Layer ' + l + '</span> ';
            html += '<strong>' + info.sentiment.toUpperCase() + '</strong>: ' + info.outlook + '</div>';
          }
        }

        if (analysis.scenarioProjections) {
          html += '<h3>' + $('tScenarioProjections') + '</h3>';
          ['conservative', 'moderate', 'aggressive', 'destructive'].forEach(rp => {
            if (analysis.scenarioProjections[rp]) {
              html += '<div style="margin:4px 0;"><strong>' + $(('scenario_' + rp)) + '</strong>: ' + analysis.scenarioProjections[rp].action + '</div>';
            }
          });
        }

        if (analysis.riskAlerts?.length > 0) {
          html += '<h3>' + $('tRiskAlerts') + '</h3>';
          analysis.riskAlerts.forEach(a => { html += '<div class="alert alert-warning">' + a + '</div>'; });
        }

        if (analysis.hbmDramOutlook) {
          html += '<h3>' + $('tHbmDram') + '</h3><p>' + analysis.hbmDramOutlook + '</p>';
        }

        content.innerHTML = html || '<pre>' + JSON.stringify(analysis, null, 2) + '</pre>';
      } catch(e) {
        content.innerHTML = '<div class="alert alert-error">' + $('tAnalysisFailed') + '<br>' + e.message + '</div>';
      }
    }

    async function refreshData() {
      await fetchAPI('/stocks/refresh', 'POST');
      await loadAll();
    }

    // Init
    applyLanguage();
    loadAll();
  </script>
</body>
</html>
