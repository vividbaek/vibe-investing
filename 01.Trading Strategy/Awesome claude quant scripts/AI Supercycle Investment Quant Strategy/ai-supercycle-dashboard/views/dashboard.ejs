    async function fetchAPI(path, method, body) {
      const opts = { method: method || 'GET', headers: {} };
      if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
      const resp = await fetch(API_BASE + path, opts);
      if (!resp.ok) throw new Error(await resp.text());
      return resp.json();
    }

    const API_BASE = '/api';

    async function loadAll() {
      await checkLlmStatus();
      setStatus(false);
      document.getElementById('statusText').textContent = llmConnected ? $('statusLoad') : $('llmDisconnected');
      try {
        await Promise.all([loadStocks(), loadStrategyComparison(), loadStrategy(currentScenario)]);
        setStatus(true);
        if (!llmConnected) {
          document.getElementById('statusText').textContent = $('llmDisconnected');
        }
      } catch(e) {
        setStatus(false);
        document.getElementById('statusText').textContent = $('statusError') + e.message;
      }
    }

    async function loadStocks() {
      const data = await fetchAPI('/stocks');
      allStocksData = data.stocks;
      document.getElementById('metricCount').textContent = data.count;
      const avgScore = data.stocks.reduce((s, x) => s + x.totalScore, 0) / data.stocks.length;
      document.getElementById('metricAvgScore').textContent = avgScore.toFixed(1);
      renderStocks(data.stocks);
    }

    function renderStocks(stocks) {
      const scoreColors = { STRONG_BUY: '#6ee7b7', BUY: '#34d399', HOLD: '#fbbf24', AVG_DOWN: '#fb923c', SELL: '#f87171', STRONG_SELL: '#ef4444' };
      const layerBadges = { 1: 'badge-layer1', 2: 'badge-layer2', 3: 'badge-layer3', 4: 'badge-layer4' };
      const marketBadges = { US: 'badge-us', KR: 'badge-kr' };

      let html = '<table><thead><tr>';
      html += '<th>#</th><th>' + $('tTableTicker') + '</th><th>' + $('tTableName') + '</th>';
      html += '<th>' + $('tTableLayer') + '</th><th>Mkt</th><th>AI%</th><th>' + $('tTableScore') + '</th>';
      html += '<th>' + $('tTablePrice') + '</th><th>MCap(B)</th><th>RevGr%</th><th>FCF%</th>';
      html += '<th>FwdPE</th><th>6M%</th><th>52wHi%</th><th>' + $('tTableAction') + '</th><th>' + $('tTableThesis') + '</th>';
      html += '</tr></thead><tbody>';
      stocks.forEach((s, i) => {
        html += '<tr>';
        html += '<td>' + (i+1) + '</td>';
        html += '<td><strong>' + s.ticker + '</strong></td>';
        html += '<td>' + (LANG === 'ko' ? (s.name || s.ticker) + (s.nameKr && s.nameKr !== s.name ? ' / ' + s.nameKr : '') : (s.name || s.ticker)) + '</td>';
        html += '<td><span class="badge ' + (layerBadges[s.layer] || '') + '">Layer ' + s.layer + '</span></td>';
        html += '<td><span class="badge ' + (marketBadges[s.market] || '') + '">' + s.market + '</span></td>';
        html += '<td>' + s.aiExposurePct + '%</td>';
        html += '<td><strong>' + s.totalScore + '</strong></td>';
        html += '<td>$' + (s.price || 0).toFixed(2) + '</td>';
        html += '<td>' + (s.marketCapB || 0).toFixed(1) + '</td>';
        html += '<td>' + (s.revenueGrowthPct || 0).toFixed(1) + '%</td>';
        html += '<td>' + (s.fcfMarginPct || 0).toFixed(1) + '%</td>';
        html += '<td>' + (s.forwardPE || 0).toFixed(1) + '</td>';
        html += '<td>' + (s.price6mPct || 0).toFixed(1) + '%</td>';
        html += '<td>' + (s.pctFrom52wHigh || 0).toFixed(1) + '%</td>';
        html += '<td><span style="color:' + (scoreColors[s.actionSignal] || '#94a3b8') + ';font-weight:700;">' + actLabel(s.actionSignal) + '</span></td>';
