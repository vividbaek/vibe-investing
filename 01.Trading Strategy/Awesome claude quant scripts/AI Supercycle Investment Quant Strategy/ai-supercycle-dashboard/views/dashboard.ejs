    async function loadStrategyComparison() {
      const profiles = ['conservative', 'moderate', 'aggressive', 'destructive'];
      try {
        const results = await Promise.all(profiles.map(p => fetchAPI('/strategy/' + p).catch(() => null)));

        let html = '<div class="card"><div class="card-header"><h3>' + (LANG === 'ko' ? '보수 → 파괴: 투자 패턴 변화' : 'Conservative → Destructive: Investment Pattern Shift') + '</h3></div>';

        // Summary matrix table
        html += '<table style="margin-bottom:12px;"><thead><tr>';
        html += '<th>' + (LANG === 'ko' ? '프로필' : 'Profile') + '</th>';
        html += '<th>' + (LANG === 'ko' ? '최소 점수' : 'Min Score') + '</th>';
        html += '<th>' + (LANG === 'ko' ? '포지션' : 'Position') + '</th>';
        html += '<th>' + (LANG === 'ko' ? '손절' : 'Stop Loss') + '</th>';
        html += '<th>' + (LANG === 'ko' ? '현금' : 'Cash') + '</th>';
