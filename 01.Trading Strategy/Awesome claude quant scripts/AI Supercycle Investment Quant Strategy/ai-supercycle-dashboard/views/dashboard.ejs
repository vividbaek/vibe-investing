        html += '<th>' + (LANG === 'ko' ? '핵심 종목' : 'Key Tickers') + '</th>';
        html += '</tr></thead><tbody>';

        profiles.forEach((profile, idx) => {
          const r = results[idx];
          if (!r || !r.signals) return;
          const cfg = r.profile;
          const layers = [];
          for (const [l, info] of Object.entries(r.layerAllocation || {})) {
            layers.push('L' + l + ':' + info.weightPct.toFixed(0) + '%');
          }
          const topTickers = (r.signals || []).slice(0, 4).map(s => s.ticker).join(', ');
          const topNames = (r.signals || []).slice(0, 4).map(s => s.ticker + (s.name ? ' ' + s.name.substring(0,12) : '')).join(', ');
          const names = ['conservative', 'moderate', 'aggressive', 'destructive'];
          const style = idx === 0 ? 'background:#05966910;' : idx === 3 ? 'background:#dc262610;' : '';

          html += '<tr style="' + style + '">';
          html += '<td><strong>' + $(('scenario_' + names[idx])) + '</strong></td>';
          html += '<td>≥' + cfg.minScoreThreshold + '</td>';
          html += '<td>' + cfg.positionSizePct + '%</td>';
          html += '<td style="color:#f87171;">' + cfg.stopLossPct + '%</td>';
          html += '<td>' + cfg.cashReservePct + '%</td>';
          html += '<td style="font-size:0.75rem;">' + layers.join(' ') + '</td>';
          html += '<td style="font-size:0.75rem;max-width:250px;">' + topNames + '</td>';
          html += '</tr>';
        });
        html += '</tbody></table>';

        // Per-profile stock breakdown
        profiles.forEach((profile, idx) => {
          const r = results[idx];
          if (!r || !r.signals || r.signals.length === 0) return;
          const names = ['conservative', 'moderate', 'aggressive', 'destructive'];
          const cfg = r.profile;
          const actionColors = { STRONG_BUY: '#6ee7b7', BUY: '#34d399', HOLD: '#fbbf24', AVG_DOWN: '#fb923c', SELL: '#f87171', STRONG_SELL: '#ef4444' };
          html += '<div style="margin-top:12px;"><strong>' + $(('scenario_' + names[idx])) + '</strong>: ';
          html += '<span style="font-size:0.8rem;color:#94a3b8;">' + cfg.description + '</span></div>';
          html += '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:4px;">';
          r.signals.forEach(s => {
            html += '<span style="padding:4px 10px;border-radius:4px;font-size:0.75rem;background:#1e293b;border:1px solid #334155;">';
            html += '<strong>' + s.ticker + '</strong> ' + (s.name || '');
            html += ' <span style="color:' + (actionColors[s.action] || '#94a3b8') + '">' + actLabel(s.action) + '</span> ';
            html += s.positionSizePct + '%';
            html += '</span>';
          });
          html += '</div>';
        });

        html += '</div>';
        document.getElementById('strategyComparison').innerHTML = html;
      } catch(e) {
        document.getElementById('strategyComparison').innerHTML = '<div class="alert alert-error">' + $('statusError') + e.message + '</div>';
      }
    }

